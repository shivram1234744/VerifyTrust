    </div>
</div>
<script>

    function ViewDetails(id) {
        window.location.href = '/Admin/Details/' + id;
    }

    const searchInput = document.getElementById("searchInput");
    const statusFilter = document.getElementById("statusFilter");
    const priorityFilter = document.getElementById("priorityFilter");

    searchInput.addEventListener("keyup", filterTable);
    statusFilter.addEventListener("change", filterTable);
    priorityFilter.addEventListener("change", filterTable);

    function filterTable() {

        let searchValue = searchInput.value.toLowerCase();
        let statusValue = statusFilter.value.toLowerCase();
        let priorityValue = priorityFilter.value.toLowerCase();

        let rows = document.querySelectorAll("#clientTable tr");

        rows.forEach(function (row) {

            let candidateName = row.cells[0]?.innerText.toLowerCase() || "";
            let caseId = row.cells[1]?.innerText.toLowerCase() || "";
            let status = row.cells[4]?.innerText.toLowerCase() || "";
            let priority = row.cells[5]?.innerText.toLowerCase() || "";

            let matchesSearch =
                candidateName.includes(searchValue) ||
                caseId.includes(searchValue);

            let matchesStatus =
                statusValue === "" || status.includes(statusValue);

            let matchesPriority =
                priorityValue === "" || priority.includes(priorityValue);

            if (matchesSearch && matchesStatus && matchesPriority) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }

        });
    }

</script>
*@