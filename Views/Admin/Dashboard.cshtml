@model TrustPlus.Models.Job_Master
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>
    .badge-pending {
        background: orange;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
    }

    .badge-progress {
        background: blue;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
    }

    .badge-complete {
        background: green;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
    }
</style>

<div class="pg-body">
    <div class="pg-intro">
        <h2>System Overview</h2>
        <p>Real-time platform statistics and activity</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">

       @TempData["SuccessMessage"] 

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }
    <div class="row g-3 mb-4 ex-stat-row">
        <div class="col">
            <div class="sc ci">
                <div class="sc-icon d-inline-flex align-items-center justify-content-center"
                     style="background:var(--s100)">
                    <svg fill="none" height="19" stroke="var(--s500)" stroke-width="2"
                         viewbox="0 0 24 24" width="19">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                    </svg>
                </div>
                <div class="sc-lbl">Total Request</div>
                <div class="sc-val">@ViewBag.d</div>
                
            </div>
        </div>
       
        <div class="col">
            <div class="sc cr">
                <div class="sc-icon d-inline-flex align-items-center justify-content-center"
                     style="background:var(--obg)">
                    <svg fill="none" height="19" stroke="orange" stroke-width="2"
                         viewBox="0 0 24 24" width="19">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 7v5l3 2"></path>
                    </svg>
                </div>
                <div class="sc-lbl">Pending</div>
                <div class="sc-val">@ViewBag.Pending</div>
            </div>
        </div>
        <div class="col">
            <div class="sc cr">
                <div class="sc-icon d-inline-flex align-items-center justify-content-center"
                     style="background:var(--bbg)">
                    <svg fill="none" height="19" stroke="blue" stroke-width="2"
                         viewBox="0 0 24 24" width="19">
                        <path d="M21 12a9 9 0 1 1-3-6.7"></path>
                        <path d="M21 3v6h-6"></path>
                    </svg>
                </div>
                <div class="sc-lbl">In Progress</div>
                <div class="sc-val">@ViewBag.InProgress</div>
            </div>
        </div>
        <div class="col">
            <div class="sc cr">
                <div class="sc-icon d-inline-flex align-items-center justify-content-center"
                     style="background:var(--gbg)">
                    <svg fill="none" height="19" stroke="green" stroke-width="2"
                         viewBox="0 0 24 24" width="19">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M8 12l3 3 5-6"></path>
                    </svg>
                </div>
                <div class="sc-lbl">Completed</div>
                <div class="sc-val">@ViewBag.Completed</div>
            </div>
        </div>

      
    </div>





