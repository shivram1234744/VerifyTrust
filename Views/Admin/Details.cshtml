    <!-- 2. Candidate Information -->
    <div class="card info-card mb-4 border-0">
        <div class="card-body p-4">

            <h4 class="info-card-title">Candidate Information</h4>
            <div class="row g-4">
                <div class="col-md-4 info-item d-flex gap-2">
                    <i class="bi bi-person icon"></i>
                    <div>
                        <div class="lbl">Name</div>
                        <div class="val">@Model.Job.EmployeeName</div>
                    </div>
                </div>
                <div class="col-md-4 info-item d-flex gap-2">
                    <i class="bi bi-envelope icon"></i>
                    <div>
                        <div class="lbl">Email</div>
                        <div class="val">@Model.Job.EmailAddress</div>
                    </div>
                </div>
                <div class="col-md-4 info-item d-flex gap-2">
                    <i class="bi bi-telephone icon"></i>
                    <div>
                        <div class="lbl">Phone</div>
                        <div class="val">@Model.Job.PhoneNumber</div>
                    </div>
                </div>
                <div class="col-md-4 info-item d-flex gap-2">
                    <i class="bi bi-calendar3 icon"></i>
                    <div>
                        <div class="lbl">Job_date</div>
                        <div class="val">@Convert.ToDateTime(@Model.Job.JobDate).ToString("yyyy-MM-dd")</div>
                    </div>
                </div>
                <div class="col-md-4 info-item d-flex gap-2">
                    <i class="bi bi-briefcase icon"></i>
                    <div>
                        <div class="lbl">Position</div>
                        <div class="val">@Model.Job.PostionApplied</div>
                    </div>
                </div>
                <div class="col-md-4 info-item d-flex gap-2">
                    <i class="bi bi-building icon"></i>
                    <div>
                        <div class="lbl">Department</div>
                        <div class="val">@Model.Job.Department</div>
                    </div>
                </div>
                <div class="col-md-4 info-item d-flex gap-2">
                    <i class="bi bi-building icon"></i>
                    <div>
                        <div class="lbl">Client Name</div>
                        <div class="val">@Model.ClientName</div>
                    </div>
                </div>
            </div>

        </div>
    </div>




