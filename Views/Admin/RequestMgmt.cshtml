    <div class="card">
        <div class="cd-hd d-flex align-items-center justify-content-between"><span class="cd-t">All Users (2,926)</span> <input type="text" class="fi m-2" style="width:150px" id="searchInput" placeholder="Search All" /></div>
        <div class="tw">
          <table class="table table-hover align-middle">

                <thead>
                    <tr><th>Job Id</th>
                        <th>Client Name</th>
                       @*  <th>Case ID</th> *@
                        <th>Employee Name</th>
                       <th>Email Address</th>
                       <th>Phone Number</th>
                       <th>Position Applied</th>
                       <th>Department</th>
                        <th>JobDate</th>
                        <th>Status</th>
                        <th>Priority</th>
                      
                     @* 
                         <th>Final Report</th>
                         <th>Final Summary</th> *@
                        @* <th>Created At</th>
                        <th>UpdatedAt</th> *@
                       

                    </tr>
                </thead>
                <tbody id="clientTable">

                    @if (Model != null)
                    {
                        foreach (var Item in Model)
                        {
                            <tr onclick="ViewDetails(@Item.JobId)" style="cursor:pointer;">
                                <td>@Item.JobId</td>
                                <td>@Item.ClientName</td>
                            @*     <td>@Item.CaseId</td> *@
                                <td>@Item.EmployeeName</td>
                                <td><strong>@Item.EmailAddress</strong></td>
                                <td>@Item.PhoneNumber</td>
                                <td>@Item.PostionApplied</td>
                                <td>@Item.Department</td>
                                  
                   <td>@(Item.JobDate?.ToString("dd MMM · hh:mm tt") ?? "-")</td>
                


                              
                          
                              @*   <td>
                                    <div style="width:120px;">

                                        <div class="d-flex justify-content-between small mb-1">
                                            <span>@Item.Progress%</span>
                                        </div>

                                        <div class="progress" style="height:6px;">
                                            <div class="progress-bar bg-success"
                                                 style="width:@Item.Progress%"></div>
                                        </div>

                                    </div>
                                </td> *@
                                <td>
                                    @{
                                        var statusClass = "";

                                        switch (Item.Status)
                                        {
                                            case "Pending":
                                                statusClass = "b-live";
                                                break;

                                            case "In Progress":
                                                statusClass = "bg-primary";
                                                break;

                                            case "Complete":
                                                statusClass = "b-completed";
                                                break;

                                            default:
                                                statusClass = "b-scheduled";
                                                break;
                                        }
                                    }

                                    <span class="badge   @statusClass">
                                        ●@Item.Status
                                    </span>
                                </td>
                                <td>
                                    @{
                                        var PriorityClass = "";

                                        switch (Item.Priority)
                                        {
                                            case "Urgent":
                                                PriorityClass = "b-live";
                                                break;

                                            case "Normal":
                                                PriorityClass = "b-completed";
                                                break;


                                            default:
                                                statusClass = "b-scheduled";
                                                break;
                                        }
                                    }


                                    <span class="badge @PriorityClass">●@Item.Priority</span>
                                </td>
                            @*     <td>@Item.FinalReport</td>
                                <td>@Item.FinalSummary</td> *@
                               @*  <td>@(Item.CreatedAt.ToString("dd MMM · hh:mm tt"))</td>
                                <td>@Item.UpdatedAt</td> *@

                            </tr>
                        }
                    }
              </tbody>


            </table>
        </div>
        <div class="pg-row d-flex justify-content-between align-items-center"><span class="pg-info">Showing 1–3 of 2,926</span><div class="pg-btns d-flex gap-1"><button class="btn btn-g btn-sm">← Prev</button><button class="btn btn-n btn-sm">1</button><button class="btn btn-g btn-sm">2</button><button class="btn btn-g btn-sm">Next →</button></div></div>
    </div>
</div>
<script>

    function ViewDetails(id) {
        window.location.href = '/Admin/Details/' + id;
    }

    const searchInput = document.getElementById("searchInput");
    const searchInputEmp = document.getElementById("searchInputEmp");
    const searchInputEmail = document.getElementById("searchInputEmail");
    const statusFilter = document.getElementById("statusFilter");
    const priorityFilter = document.getElementById("priorityFilter");

    searchInput.addEventListener("keyup", filterTable);
    searchInputEmp.addEventListener("keyup", filterTable);
    searchInputEmail.addEventListener("keyup", filterTable);
    statusFilter.addEventListener("change", filterTable);
    priorityFilter.addEventListener("change", filterTable);

    function filterTable() {
        let searchValue = searchInput.value.toLowerCase().trim();
        let searchValueEmp = searchInputEmp.value.toLowerCase().trim();
        let searchValueEmail = searchInputEmail.value.toLowerCase().trim();
        let statusValue = statusFilter.value.toLowerCase().trim();
        let priorityValue = priorityFilter.value.toLowerCase().trim();

        let rows = document.querySelectorAll("#clientTable tr");

        rows.forEach(function (row) {
            // 1. Fetch text data from target cells accurately
            let employeeName = row.cells[2]?.innerText.toLowerCase() || "";
            let email = row.cells[3]?.innerText.toLowerCase() || "";
            let status = row.cells[8]?.innerText.toLowerCase() || "";
            let priority = row.cells[9]?.innerText.toLowerCase() || "";

            // Full row text for the original catch-all search box
            let allRowText = row.innerText.toLowerCase();

            // 2. Separate logic conditions per individual input element
            let matchesGlobalSearch = searchValue === "" || allRowText.includes(searchValue);
            let matchesEmpSearch = searchValueEmp === "" || employeeName.includes(searchValueEmp);
            let matchesEmailSearch = searchValueEmail === "" || email.includes(searchValueEmail);

            let matchesStatus = statusValue === "" || status.includes(statusValue);
            let matchesPriority = priorityValue === "" || priority.includes(priorityValue);

            // 3. Row displays only if it passes every active filter condition
            if (matchesGlobalSearch && matchesEmpSearch && matchesEmailSearch && matchesStatus && matchesPriority) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    }
</script>