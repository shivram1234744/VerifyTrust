    <!-- 3. Verification Checks -->
    <div class="card info-card mb-4 border-0">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-end mb-2">
                <div>
                    @{
                        var data = ViewBag.VarData as IEnumerable<dynamic> ?? new List<dynamic>();

                        int total = data.Count();

                        int completed = data.Count(x => x.Status != null
                        && x.Status.ToString() == "Completed");

                        int progress = total > 0 ? (completed * 100) / total : 0;
                    }


                    <h4 class="info-card-title mb-1">Verification Checks</h4>
                    @* <div class="text-muted small">0/@ViewBag.VarData.Count checks completed · 0% progress</div> *@
                    <div class="text-muted small">
                        @completed/@total checks completed · @progress% progress
                    </div>
                </div>
                <div class="fw-bold text-primary fs-5">@progress%</div>
            </div>

            <div class="progress progress-custom mb-4">
                <div class="progress-bar"
                     role="progressbar"
                     style="width:@progress%"
                     aria-valuenow="@progress"
                     aria-valuemin="0"
                     aria-valuemax="100">
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-custom table-borderless mb-0">
                    <thead>
                        <tr>
                            <th>Check Type</th>
                            <th>Status</th>
                            <th>Flag Result</th>
                            <th>Executor Notes</th>
                            <th>Final Report</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.VarData != null)
                        {
                            foreach (var row in ViewBag.VarData)
                            {
                                <tr>
                                    <td class="fw-medium">@row.VarificationName</td>
                                    <td>
                                        @{
                                            var statusClass = row.Status switch
                                            {
                                                "Pending" => "badge-pending",
                                                "In Progress" => "badge-progress",
                                                "Completed" => "badge-completed",
                                                _ => "badge-pending"
                                            };
                                        }
                                        <span class="@statusClass">@row.Status</span>
                                    </td>
                                    <td class="text-muted">@row.IssueType</td>
                                    <td class="text-muted">@row.ExcuterRemark</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(row.EvidanceDocument))
                                        {
                                            <a href="/uploads/@row.EvidanceDocument"
                                               target="_blank"
                                               class="btn btn-sm btn-primary">Show</a>
                                            <a href="/uploads/@row.EvidanceDocument"
                                               download
                                               class="btn btn-sm btn-success">Download</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No File</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>

                </table>
            </div>
        </div>
    </div>

    <!-- 4. Bottom Section: Activity Log & Comments -->
    <div class="row g-4">

        


       

        <!--  Document Section  -->



        <div class="card-body p-4 m-4">


            <h5 class="info-card-title mb-4">Documents</h5>
            <div class="d-flex flex-column gap-3">
                @if (Model.Documents != null && Model.Documents.Any())
                {
                    foreach (var doc in Model.Documents)
                    {
                        <div class="d-flex justify-content-between align-items-center p-3 rounded" style="background-color: #f8f9fa;">
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi bi-file-earmark-text text-primary fs-5"></i>
                                <span class="fw-medium" style="color: #4b5563; font-size: 0.95rem;">
                                    @doc.DocumentName
                                </span>
                            </div>

                            <a href="/uploads/documents/@doc.DocumentName"
                               target="_blank"
                               class="text-secondary text-xl"
                               download
                               title="Download @doc.DocumentName">
                                <i class="bi bi-download"></i> <br />Download
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="text-muted text-center py-3">No documents uploaded yet for this job.</div>
                }
            </div>
        </div>

        
        <!-- Comments Section (Full width in its container, can be placed below or side-by-side) -->
     

    </div>

</div>