     $(document).ready(function () {
         $.ajax({
             url: '/Admin/GetData',
             type: 'GET',
             success: function (data) {
                 // Clear old options
                 $("#job").empty();

                 // Add default option
                 $("#job").append('<option value="">-- Select Emp --</option>');

                 // Build options
                 var row = '';
                 $.each(data, function (i, e) {
                     row += `<option value="${e.employeeId}">${e.name}</option>`;
                 });

                 // Append to dropdown
                 $("#job").append(row);
             },
             error: function (xhr, status, error) {
                 alert("Error: " + error);
             }
         });

     })

     $(document).ready(function () {
         $.ajax({
             url: '/Admin/GetCompanies',
             type: 'GET',
             success: function (response) {
                 console.log(response)
                 //clear old option
                 $("#company").empty()

                 //add default option
                 $("#company").append('<option value="">--select company--</option>')

                 //Build options
                 var row = '';
                 $.each(response, function (i, e) {
                     row += `<option value="${e.clientId}">${e.clientName}</option>`;


                 })
                 console.log(row)
                 //Append to dropdown
                 $("#company").append(row)
             },
             error: function (xhr, status, error) {
                 alert("Error " + error)
             }

         })
     })

     $(document).on("click", "#saveJobBtn", function () {

         var empid = $("#job").val();
         var companyId = $("#company").val();

         // Get clientId from URL
         var pathParts = window.location.pathname.split('/');
         var clientId = pathParts[pathParts.length - 1];

         if (!empid) {
             alert("Please select an employee..");
             return;
         }

         $.ajax({
             url: '/Client/SaveEmpInClient',
             type: 'POST',
             data: { id: empid, clientId: clientId, companyId: companyId, },
             success: function (response) {
                 if (response.success) {
                     alert(response.message);
                     location.href = '/Admin/Dashboard'
                 } else {
                     alert(response.message);
                 }
             },
             error: function (res) {
                 alert("Server Error");
             }
         });
     });
