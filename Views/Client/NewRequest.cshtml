                 alert("Error loading clients: " + error);
             }
         });
     });

</script>
<script>
    $(document).ready(function () {
        // C# ViewBag se values ko JavaScript variables me lein

        var clientSessionId = '@ViewBag.LoggedInClientId';

        // Agar login hone wala user "Client" hai, toh auto-select karein
        if (clientSessionId !== "") {

            // Dropdown me client ki ID set karein
            $("#clientSelect").val(clientSessionId);

            // Client khud ka dropdown change na kar sake, isliye disable karein
            $("#clientSelect").prop("disabled", true);

         
            $("<input>").attr({
                type: "hidden",
                name: "ClientId",
                value: clientSessionId
            }).appendTo("form");
        }
    });
</script>

}