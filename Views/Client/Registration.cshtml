
@{
    Layout = null;
}


<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Registration</title>
    <!-- Latest Stable Bootstrap 5 Link -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light py-5">

    <div class="container">
        <div class="card shadow-sm border-0 mx-auto" style="max-width: 800px;">
            <div class="card-header bg-primary text-white p-3">
                <h4 class="mb-0 fw-bold">Client Registration</h4>
            </div>
            <div class="card-body p-4">
                
               
                <form method="post" enctype="multipart/form-data">
                    <div class="row g-3">
                     
                        <div class="col-sm-6">
                            <label class="form-label fw-medium">Client Name</label>
                            <input type="text" class="form-control" name="ClientName" placeholder="Enter Name" required />
                        </div>
                 
                        <div class="col-sm-6">
                            <label class="form-label fw-medium">Web Address</label>
                            <input type="text" class="form-control" name="WebAddress" placeholder="Enter Web Address" />
                        </div>

                        
                        <div class="col-sm-6">
                            <label class="form-label fw-medium">Phone Number</label>
                            <input type="text" class="form-control" name="MobileNumber" placeholder="Enter Phone Number" />
                        </div>

                      
                  <div class="col-sm-6">
                            <label class="form-label fw-medium">Contact Persone</label>
                            
                            <input type="text" class="form-control" id="txtEmail" name="ContactPerson" placeholder="Enter Contact Persone" required />
                        </div>

                    
                        <div class="col-sm-6">
                            <label class="form-label fw-medium">User ID</label>
                         
                            <input type="text" class="form-control" id="txtUserId" name="CUserId" placeholder="Enter User ID" required />
                        </div>

                    
                        <div class="col-sm-6">
                            <label class="form-label fw-medium">Password</label>
                            <input type="password" class="form-control" id="txtPassword" name="CPassword" placeholder="Enter Password" required />
                        </div>

              
                        <div class="col-12">
                            <label class="form-label fw-medium">Address</label>
                          
                            <textarea class="form-control" rows="3" name="Address" placeholder="Enter Complete Address"></textarea>
                        </div>

                     
                     
                 
                    
                        <div class="col-12 text-end mt-4">
                            <button type="submit" class="btn btn-primary px-4 py-2 fw-medium">Submit Registration</button>
                        </div>

                    </div>
                </form>

            </div>
        </div>
    </div>

</body>
</html>
