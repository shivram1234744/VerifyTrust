@model List<TrustPlus.Models.JobWithDetailsViewModel>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_ExecutorLayout.cshtml";
}

<style>
    .badge-pending {
        background: orange;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
    }

    .badge-progress {
        background: blue;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
    }

    .badge-complete {
        background: green;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
    }
</style>

<div class="pg-body">
    <div class="pg-intro">
        <h2>System Overview</h2>
        <p>Real-time platform statistics and activity</p>
    </div>
    <div class="row g-3 mb-4 ex-stat-row">
        <div class="col">
            <div class="sc ci">
                <div class="sc-icon d-inline-flex align-items-center justify-content-center"
                     style="background:var(--s100)">
                    <svg fill="none" height="19" stroke="var(--s500)" stroke-width="2"
                         viewbox="0 0 24 24" width="19">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                    </svg>
                </div>
                <div class="sc-lbl">Total Request</div>
                <div class="sc-val">@Model.Count</div>
                
            </div>
        </div>
       
        <div class="col">
            <div class="sc cr">
                <div class="sc-icon d-inline-flex align-items-center justify-content-center"
                     style="background:var(--obg)">
                    <svg fill="none" height="19" stroke="orange" stroke-width="2"
                         viewBox="0 0 24 24" width="19">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 7v5l3 2"></path>
                    </svg>
                </div>
                <div class="sc-lbl">Pending</div>
                <div class="sc-val">@ViewBag.Pending</div>
            </div>
        </div>
        <div class="col">
            <div class="sc cr">
                <div class="sc-icon d-inline-flex align-items-center justify-content-center"
                     style="background:var(--bbg)">
                    <svg fill="none" height="19" stroke="blue" stroke-width="2"
                         viewBox="0 0 24 24" width="19">
                        <path d="M21 12a9 9 0 1 1-3-6.7"></path>
                        <path d="M21 3v6h-6"></path>
                    </svg>
                </div>
                <div class="sc-lbl">In Progress</div>
                <div class="sc-val">@ViewBag.InProgress</div>
            </div>
        </div>
        <div class="col">
            <div class="sc cr">
                <div class="sc-icon d-inline-flex align-items-center justify-content-center"
                     style="background:var(--gbg)">
                    <svg fill="none" height="19" stroke="green" stroke-width="2"
                         viewBox="0 0 24 24" width="19">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M8 12l3 3 5-6"></path>
                    </svg>
                </div>
                <div class="sc-lbl">Completed</div>
                <div class="sc-val">@ViewBag.Completed</div>
            </div>
        </div>

      
    </div>

    
   
        
    <div class="card" style="margin-bottom:14px">
        <div class="d-flex gap-2 flex-wrap align-items-center">
            <input type="text" class="fi m-2" style="width:150px" id="searchInputEmp" placeholder="Search by Employee Name" />
            <input type="text" class="fi m-2" style="width:150px" id="searchInputEmail" placeholder="Search by Email" />

         
            @* <div class="hs" style="flex:1;min-width:180px"><svg fill="none" height="14" stroke="var(--g300)" stroke-width="2" viewbox="0 0 24 24" width="14">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" x2="16.65" y1="21" y2="16.65"></line></svg>
                <input type="text" id="searchInput" placeholder="Search by name, ID…" />
            </div> *@
            <select class="fi" style="width:150px" id="statusFilter">
                <option value="">All Status</option>
                <option value="Pending">Pending</option>
                <option value="In Progress">In Progress</option>
                <option value="Complete">Complete</option>
            </select>

            <select class="fi" style="width:150px" id="priorityFilter">
                <option value="">All Priority</option>
                <option value="Urgent">Urgent</option>
                <option value="Normal">Normal</option>
            </select>


           

@*             <button type="button" class="text-light bg-primary p-2 px-5 m-2 border-0 rounded" onclick="search()">Filter</button>
 *@        </div>
    </div>
    <div class="card">
        <div class="cd-hd d-flex align-items-center justify-content-between">
            <span class="cd-t">All Users (2,926)</span>            <input type="text" id="searchInput" class="fi" style="width:150px" placeholder="Search by All" />
        </div>
        <div class="tw">
    

<table class="table table-bordered table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Job Id</th>
            <th>Client Name</th>
           @*  <th>Case ID</th> *@
            <th>Employee Name</th>
            <th>Email Address</th>
            <th>Phone Number</th>
            <th>Position Applied</th>
            <th>Department</th>
            <th>JobDate</th>
            <th>Status</th>
            <th>Priority</th>
            @* <th>Created At</th>
            <th>Updated At</th> *@
      
        </tr>
    </thead>
                <tbody id="clientTable">
        @foreach (var job in Model)
        {
                        <tr onclick="ViewDetails(@job.JobId)" style="cursor:pointer;">
                <td>@job.JobId</td>
                <td>@job.ClientName</td>
              @*   <td>@job.CaseId</td> *@
                <td>@job.EmployeeName</td>
                <td>@job.EmailAddress</td>
                <td>@job.PhoneNumber</td>
                <td>@job.PostionApplied</td>
                <td>@job.Department</td>
                <td>@job.JobDate.ToString()</td>
                <td>@job.Status</td>
                <td>@job.Priority</td>
               @*  <td>@job.CreatedAt.ToString("dd MMM yyyy hh:mm tt")</td>
                <td>@job.UpdatedAt.ToString()</td>
              *@
            </tr>
        }
    </tbody>
</table>

        </div>
        <div class="pg-row d-flex justify-content-between align-items-center"><span class="pg-info">Showing 1–3 of 2,926</span><div class="pg-btns d-flex gap-1"><button class="btn btn-g btn-sm">← Prev</button><button class="btn btn-n btn-sm">1</button><button class="btn btn-g btn-sm">2</button><button class="btn btn-g btn-sm">Next →</button></div></div>
    </div>
</div>
<script>

    function ViewDetails(id) {
        window.location.href = '/Executor/Details/' + id;
    }

    const searchInput = document.getElementById("searchInput");
    const searchInputEmp = document.getElementById("searchInputEmp");
    const searchInputEmail = document.getElementById("searchInputEmail");
    const statusFilter = document.getElementById("statusFilter");
    const priorityFilter = document.getElementById("priorityFilter");

    searchInput.addEventListener("keyup", filterTable);
    searchInputEmp.addEventListener("keyup", filterTable);
    searchInputEmail.addEventListener("keyup", filterTable);
    statusFilter.addEventListener("change", filterTable);
    priorityFilter.addEventListener("change", filterTable);
    function search(){
        alert("ok")
    }
    function filterTable() {
        let searchValue = searchInput.value.toLowerCase().trim();
        let searchValueEmp = searchInputEmp.value.toLowerCase().trim();
        let searchValueEmail = searchInputEmail.value.toLowerCase().trim();
        let statusValue = statusFilter.value.toLowerCase().trim();
        let priorityValue = priorityFilter.value.toLowerCase().trim();

        let rows = document.querySelectorAll("#clientTable tr");

        rows.forEach(function (row) {
            // 1. Fetch text data from target cells accurately
            let employeeName = row.cells[2]?.innerText.toLowerCase() || "";
            let email = row.cells[3]?.innerText.toLowerCase() || "";
            let status = row.cells[8]?.innerText.toLowerCase() || "";
            let priority = row.cells[9]?.innerText.toLowerCase() || "";

            // Full row text for the original catch-all search box
            let allRowText = row.innerText.toLowerCase();

            // 2. Separate logic conditions per individual input element
            let matchesGlobalSearch = searchValue === "" || allRowText.includes(searchValue);
            let matchesEmpSearch = searchValueEmp === "" || employeeName.includes(searchValueEmp);
            let matchesEmailSearch = searchValueEmail === "" || email.includes(searchValueEmail);

            let matchesStatus = statusValue === "" || status.includes(statusValue);
            let matchesPriority = priorityValue === "" || priority.includes(priorityValue);

            // 3. Row displays only if it passes every active filter condition
            if (matchesGlobalSearch && matchesEmpSearch && matchesEmailSearch && matchesStatus && matchesPriority) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    }
</script>