<script>
    /* ── MOBILE SIDEBAR TOGGLE ── */
    (function () {
    var toggle = document.getElementById('ex-mob-toggle');
    var sidebar = document.getElementById('ex-sidebar');
    var overlay = document.getElementById('ex-sidebar-overlay');
    if (!toggle || !sidebar) return;
    function open() { sidebar.classList.add('ex-sidebar-open'); if (overlay) overlay.classList.add('show'); document.body.style.overflow = 'hidden'; }
    function close() { sidebar.classList.remove('ex-sidebar-open'); if (overlay) overlay.classList.remove('show'); document.body.style.overflow = ''; }
    toggle.addEventListener('click', function (e) { e.stopPropagation(); sidebar.classList.contains('ex-sidebar-open') ? close() : open(); });
    if (overlay) overlay.addEventListener('click', close);
    sidebar.querySelectorAll('.ni').forEach(function (n) { n.addEventListener('click', function () { if (window.innerWidth < 992) close(); }); });
    })();
</script>
@RenderSection("Scripts", required: false)
